# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# Resend Email Service (get your API key at https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# Email sender (use your verified domain in production)
EMAIL_FROM=Pantry Tracker <onboarding@resend.dev>

# Set to 'true' to send digest immediately on startup (for testing)
RUN_DIGEST_ON_START=false
